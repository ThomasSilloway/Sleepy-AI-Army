GEMINI_API_KEY="YOUR_API_KEY_HERE"

# Optional: Specific Gemini model for the summarizer in PoC-9
GEMINI_SUMMARIZER_MODEL_NAME="gemini-1.5-flash-latest"

# Optional: Logging configuration
LOG_LEVEL="INFO" # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_TO_FILE="false" # true or false
LOG_FILE_PATH="poc9_app.log" # Path to the log file if LOG_TO_FILE is true

# Optional: Input text for the summarization task
POC9_INPUT_TEXT="LangGraph is a powerful library for building stateful, multi-actor applications with LLMs."
